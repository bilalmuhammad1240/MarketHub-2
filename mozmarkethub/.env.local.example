# Copie este ficheiro para .env.local e preencha com os valores
# do seu projeto Supabase (Project Settings > API).

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Apenas para uso em rotas de servidor com privilégios de admin.
# NUNCA exponha esta chave no frontend.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
